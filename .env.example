# Example local env for deploying the pipeline (copy to .env.local)
# IMPORTANT: Do not commit your real .env.local

export AWS_REGION=eu-central-1
export APP_NAME=address-splitter
export STAGE=dev
export GITHUB_REPO=danielpradilla/address-splitter
export GITHUB_BRANCH=main
export CODESTAR_ARN=arn:aws:codeconnections:<region>:<account-id>:connection/<connection-id>

# Loqate (Addressy) API
# For cloud runtime, set this to a Secrets Manager secret id/name/ARN.
# Secret JSON must contain: {"LOQATE_API_KEY":"..."}
export LOQATE_SECRET_ID=""
# Local-only fallback (not used by Lambda in AWS unless you explicitly inject it there):
# export LOQATE_API_KEY=""
# Optional
# export LOQATE_BASE_URL="https://api.addressy.com"
# export LOQATE_LANGUAGE=""
